# Git ignore rules for AgriSense project

# ── Environment Variables (NEVER commit these!)
.env
*.env

# ── Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual Environment
venv/
env/
.venv/
ENV/

# ── Trained Model Weights (too large for Git — use Git LFS or DVC)
# model/*.pth
# model/*.pt
# model/*.onnx

# ── Dataset (too large for Git)
dataset/
*.csv
*.zip
*.tar.gz

# ── Uploads (user uploaded images)
uploads/*
!uploads/.gitkeep

# ── Jupyter
.ipynb_checkpoints/
*.ipynb~

# ── IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker
.dockerignore
*.tar

# ── Logs
*.log
logs/

# ── Testing
.coverage
htmlcov/
.pytest_cache/
