# AgriSense Environment Variables
# Copy this file to .env and fill in your values

# ────────────────────────────────────────────
# REQUIRED: Groq API Key for LLM Advisory
# Get free key at: https://console.groq.com
# ────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ────────────────────────────────────────────
# Flask Configuration
# ────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_for_sessions
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000
